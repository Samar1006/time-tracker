# Copy to .env and fill in. Never commit the real .env.
# All keys are optional — the server runs offline (in-memory + heuristics) without them.

# Deepgram speech-to-text (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Claude (Anthropic) — refines schedule parsing for messier input.
# If unset, the heuristic parser is used. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Redis — persists raw activity events (Samar's ingestion) and powers optional
# vector-similarity categorization. If unset/unreachable, events fall back to
# in-memory storage and categorization falls back to keyword matching.
REDIS_URL=

# JWT signing secret for login sessions. Defaults to a dev-only value if unset.
JWT_SECRET=

# Google OAuth Client ID. Required for real "Continue with Google" login.
# Backend: copy this file to .env and set GOOGLE_CLIENT_ID to the OAuth web client ID.
# Frontend: keep environment*.ts committed with googleClientId: ''.
# For local demos or deployment, inject the same OAuth web client ID into the Angular
# environment config without committing secrets/config values to git.
GOOGLE_CLIENT_ID=

PORT=4000
